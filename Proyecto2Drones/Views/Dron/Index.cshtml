@model Proyecto2Drones.Models.LectorXML

@{
    ViewData["Title"] = "Gestión de Drones";
}

<div class="container mt-5">
    @* --- ENCABEZADO --- *@
    <div class="text-center mb-5 p-4 bg-light rounded shadow-sm border-start border-primary border-5">
        <h1 class="display-4 text-primary"><i class="bi bi-cpu"></i> Panel de Control de Drones</h1>
        <p class="lead text-secondary">Carga configuraciones XML y gestiona la flota de drones para la simulación</p>
    </div>

    @* --- BOTONES DE ACCIÓN PRINCIPALES --- *@
    <div class="mb-4 d-flex gap-2">
        <a asp-action="Inicializar" class="btn btn-danger">
            <i class="bi bi-trash"></i> Inicializar Sistema
        </a>
        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalDron">
            <i class="bi bi-plus-circle"></i> Agregar Dron
        </button>
        <a asp-action="VerGraficaSistemas" target="_blank" class="btn btn-info text-white">
            <i class="bi bi-diagram-3"></i> Ver Gráfica de Sistemas
        </a>
        <a asp-action="Ayuda" class="btn btn-secondary">
            <i class="bi bi-question-circle"></i> Ayuda
        </a>
    </div>

    @* --- MODAL PARA AGREGAR DRON (INCISO D.b) --- *@
    <div class="modal fade" id="modalDron" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="AgregarDronManual" method="post" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo Dron Manual</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Nombre del Dron:</label>
                    <input type="text" name="nombreDron" class="form-control" placeholder="Ej: DronNuevo1" required />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar Dron</button>
                </div>
            </form>
        </div>
    </div>

    @* --- FORMULARIO DE CARGA XML --- *@
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <h5 class="card-title mb-4 fw-bold"><i class="bi bi-file-earmark-code"></i> Subir Configuración XML</h5>
            <form asp-action="CargarXML" method="post" enctype="multipart/form-data" class="row g-3">
                <div class="col-md-8">
                    <input type="file" name="archivo" class="form-control form-control-lg" accept=".xml" required />
                </div>
                <div class="col-md-4 d-grid">
                    <button type="submit" class="btn btn-primary btn-lg shadow">
                        <i class="bi bi-play-fill"></i> Cargar y Procesar
                    </button>
                </div>
            </form>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }
        </div>
    </div>

    @* --- TABLA DE GESTIÓN DE MENSAJES (INCISO F - SELECCIÓN) --- *@
    @if (Model != null && Model.listaResultados != null && Model.listaResultados.GetConteo() > 0)
    {
        <div class="card shadow-sm mb-5 border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-list-check"></i> Listado de Mensajes Procesados (Inciso F)</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mensaje</th>
                            <th>Sistema Utilizado</th>
                            <th>Tiempo Óptimo</th>
                            <th>Mensaje Decodificado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.listaResultados.GetConteo(); i++)
                        {
                            var res = Model.listaResultados.Obtener(i);
                            <tr>
                                <td><strong>@res.NombreMensaje</strong></td>
                                <td>@res.NombreSistema</td>
                                <td><span class="badge bg-info text-dark">@res.TiempoOptimo s</span></td>
                                <td><code>@res.MensajeDecoded</code></td>
                                <td class="text-center">
                                    <a asp-action="VerGraficaMensaje" asp-route-nombre="@res.NombreMensaje" target="_blank" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-diagram-3-fill"></i> Ver Gráfica DOT
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* --- BOTÓN DE DESCARGA --- *@
        <div class="d-flex justify-content-end mb-4">
            <a asp-controller="Dron" asp-action="DescargarXML" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-file-earmark-arrow-down"></i> Descargar Respuesta XML
            </a>
        </div>

        @* --- SIMULACIÓN DETALLADA (PASO A PASO) --- *@
        <h3 class="fw-bold text-primary mb-4"><i class="bi bi-r-circle-fill"></i> Detalle de Simulación en Paralelo</h3>
        @for (int i = 0; i < Model.listaResultados.GetConteo(); i++)
        {
            var respuesta = Model.listaResultados.Obtener(i);
            if (respuesta != null && respuesta.Pasos.GetConteo() > 0)
            {
                <div class="card shadow-sm mb-5 border-primary">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Simulación: <strong>@respuesta.NombreMensaje</strong></h5>
                        <span class="badge bg-light text-primary">@respuesta.Pasos.GetConteo() Segundos Totales</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-bordered mb-0 text-center align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th style="width: 80px;">Tiempo</th>
                                        @{
                                            var primerSegundo = respuesta.Pasos.Obtener(0);
                                            for (int d = 0; d < primerSegundo.Movimientos.GetConteo(); d++)
                                            {
                                                <th>@primerSegundo.Movimientos.Obtener(d).NombreDron</th>
                                            }
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int j = 0; j < respuesta.Pasos.GetConteo(); j++)
                                    {
                                        var paso = respuesta.Pasos.Obtener(j);
                                        <tr>
                                            <td class="fw-bold bg-light">@paso.Segundo s</td>
                                            @for (int d = 0; d < primerSegundo.Movimientos.GetConteo(); d++)
                                            {
                                                var nombreDronColumna = primerSegundo.Movimientos.Obtener(d).NombreDron;
                                                string accionDron = "Esperar";

                                                for (int m = 0; m < paso.Movimientos.GetConteo(); m++) {
                                                    var mov = paso.Movimientos.Obtener(m);
                                                    if (mov.NombreDron.Trim().Equals(nombreDronColumna.Trim(), StringComparison.OrdinalIgnoreCase)) {
                                                        accionDron = mov.Accion;
                                                        break;
                                                    }
                                                }

                                                <td>
                                                    @if (accionDron == "Emitir Luz") { <span class="badge bg-warning text-dark"><i class="bi bi-lightbulb"></i> Luz</span> }
                                                    else if (accionDron == "Subir") { <span class="text-primary fw-semibold">&#8593; Subir</span> }
                                                    else if (accionDron == "Bajar") { <span class="text-danger fw-semibold">&#8595; Bajar</span> }
                                                    else { <span class="text-muted">Esperar</span> }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }

    @* --- INVENTARIO GLOBAL (INCISO D.a) --- *@
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
            <h3 class="fw-bold"><i class="bi bi-airplane-engines"></i> Inventario de Drones</h3>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 10%;">#</th>
                            <th>Nombre del Dron</th>
                            <th class="text-end">Estado Global</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.listaDronesGlobal != null && Model.listaDronesGlobal.GetConteo() > 0)
                        {
                            for (int i = 0; i < Model.listaDronesGlobal.GetConteo(); i++)
                            {
                                var dron = Model.listaDronesGlobal.Obtener(i);
                                <tr>
                                    <td class="fw-bold text-secondary">@(i + 1)</td>
                                    <td>@dron.Nombre</td>
                                    <td class="text-end"><span class="badge bg-success rounded-pill">Registrado</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">No se han cargado drones.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* --- CONFIGURACIÓN DE SISTEMAS (INCISO E) --- *@
@if (Model != null && Model.listaSistemasDrones != null && Model.listaSistemasDrones.GetConteo() > 0)
{
    <h3 class="fw-bold text-dark mb-4"><i class="bi bi-gear-wide-connected"></i> Configuración de Sistemas</h3>
    @for (int i = 0; i < Model.listaSistemasDrones.GetConteo(); i++)
    {
        var sistema = Model.listaSistemasDrones.Obtener(i);
        
        @* --- ESTA ES LA LÍNEA QUE DEBES AGREGAR PARA OCULTAR LA TABLA VACÍA --- *@
        if (sistema != null && sistema.DronesConfigurados.GetConteo() > 0) 
        {
            <div class="card shadow-sm mb-5">
                <div class="card-header bg-dark text-white d-flex justify-content-between">
                    <span><strong>Sistema:</strong> @sistema.Nombre</span>
                    <span><strong>Altura Máx:</strong> @sistema.AlturaMaxima m</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        @for (int j = 0; j < sistema.DronesConfigurados.GetConteo(); j++)
                        {
                            var config = sistema.DronesConfigurados.Obtener(j);
                            <div class="col-md-4 mb-3">
                                <div class="card border-secondary h-100">
                                    <div class="card-header bg-light py-1 fw-bold text-secondary text-truncate">
                                        <small title="@config.NombreDron"><i class="bi bi-gpu-card"></i> @config.NombreDron</small>
                                    </div>
                                    <ul class="list-group list-group-flush">
                                        @for (int k = 0; k < config.ListadoAlturas.GetConteo(); k++)
                                        {
                                            var alt = config.ListadoAlturas.Obtener(k);
                                            <li class="list-group-item d-flex justify-content-between p-2">
                                                <small>Alt: @alt.ValorAltura</small>
                                                <span class="badge border border-primary text-primary">@alt.Letra</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        } @* --- AQUÍ CIERRA EL IF QUE AGREGASTE --- *@
    }
}